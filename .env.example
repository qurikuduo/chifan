# 吃饭 - 家庭菜单协作平台 环境配置
# 使用方法：复制此文件为 .env，然后修改以下配置

# [必填] JWT 签名密钥（生产环境必须修改）
# 生成方法：openssl rand -hex 32
JWT_SECRET=change-me-in-production

# [可选] 允许的前端域名（生产环境应设为具体域名，如 https://your-domain.com）
CORS_ORIGIN=*

# [可选] 服务端口
PORT=8787

# [可选] 首次初始化时的管理员密码（首次启动后请立即通过Web界面修改）
ADMIN_PASSWORD=admin123456
